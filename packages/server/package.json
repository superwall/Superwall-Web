{
  "name": "@superwall/server",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./verify": {
      "types": "./src/verify.ts",
      "default": "./src/verify.ts"
    }
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "echo 'no-op for v0; consumers import .ts directly via Bun/Vite/Next ESM'",
    "clean": "rm -rf node_modules .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@superwall/core": "workspace:^",
    "@superwall/verify": "workspace:^"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
