{
  "name": "@superwall/paywalls-js",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "./src/browser/auto.ts"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./browser": {
      "types": "./src/browser/index.ts",
      "default": "./src/browser/index.ts"
    },
    "./browser/auto": {
      "types": "./src/browser/auto.ts",
      "default": "./src/browser/auto.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "echo 'no-op for v0; consumers import .ts directly via Bun/Vite/Next ESM'",
    "clean": "rm -rf node_modules .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@superwall/core": "workspace:^",
    "@superwall/superscript": "^1.0.2",
    "effect": "^3.18.0"
  },
  "devDependencies": {
    "@effect/language-service": "^0.40.0",
    "@effect/vitest": "^0.29.0",
    "@happy-dom/global-registrator": "^15.0.0",
    "@types/bun": "latest",
    "happy-dom": "^20.10.6",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  }
}
