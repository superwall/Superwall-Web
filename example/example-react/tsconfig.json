{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@superwall/paywalls-js": ["../../packages/paywalls-js/src/index.ts"],
      "@superwall/paywalls-js/browser": ["../../packages/paywalls-js/src/browser/index.ts"],
      "@superwall/paywalls-react": ["../../packages/paywalls-react/src/index.ts"],
      "@superwall/server": ["../../packages/server/src/index.ts"],
      "@superwall/core": ["../../packages/core/src/index.ts"]
    },

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },

  "exclude": ["dist", "node_modules"]
}
